{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "rootDir": ".",
    "outDir": "dist-tests",
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
